# ---- P Profile environment ----
# Copy this file to ".env" and fill in the values.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pprofile

# Secret used to sign the auth session cookie (required in production).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=dev-only-change-me

# HTTP port the combined API + client server listens on
PORT=5000

# development | production
NODE_ENV=development

# Where uploaded documents are stored on local disk (local storage adapter).
# Swap the storage adapter (server/lib/storage.ts) for S3/GCS later without schema changes.
UPLOAD_DIR=./uploads
